# ══════════════════════════════════════════════════════════════
# Environment Variables — Wedding Invitation SaaS
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and update values for production.

# ── Backend ─────────────────────────────────────────────────────
BACKEND_PORT=3001
DB_PATH=/app/data/wedding.db
FRONTEND_URL=http://localhost

# ── Frontend ───────────────────────────────────────────────────
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=/api/v1

# ── Nginx ───────────────────────────────────────────────────────
NGINX_PORT=80
NGINX_SSL_PORT=443
